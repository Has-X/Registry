<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Registry_App.Pages.JournalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Registry_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,18,24,18" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="24"
                    FontWeight="SemiBold"
                    Text="Journal" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Restore previous states captured before changes made in Registry."
                    TextWrapping="Wrap" />
            </StackPanel>
            <Border
                Grid.Column="1"
                MinWidth="92"
                Padding="10,5"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <TextBlock
                    x:Name="JournalCountText"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Border>
        </Grid>

        <Border
            Grid.Row="1"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <ListView
                    x:Name="JournalList"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:JournalRow">
                            <Grid MinHeight="66" Padding="14,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Width="32"
                                    Height="32"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <FontIcon
                                        FontSize="15"
                                        Glyph="&#xE81C;"
                                        VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ActionName}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Path}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind CreatedText}" />
                                </StackPanel>
                                <Button
                                    Grid.Column="2"
                                    Padding="10,5"
                                    Background="{ThemeResource AccentButtonBackground}"
                                    Click="Restore_Click"
                                    Foreground="{ThemeResource AccentButtonForeground}"
                                    Tag="{x:Bind Entry}"
                                    ToolTipService.ToolTip="Restore this snapshot">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE777;" />
                                        <TextBlock Text="Restore" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Grid.Column="3"
                                    Padding="10,5"
                                    Click="Remove_Click"
                                    Tag="{x:Bind Entry}"
                                    ToolTipService.ToolTip="Remove from journal">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                        <TextBlock Text="Remove" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    x:Name="EmptyState"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
                    <FontIcon
                        FontSize="30"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Glyph="&#xE81C;" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="No journal snapshots yet." />
                </StackPanel>
            </Grid>
        </Border>

        <InfoBar
            x:Name="JournalStatus"
            Grid.Row="2"
            IsClosable="False"
            IsOpen="False" />
    </Grid>
</Page>
