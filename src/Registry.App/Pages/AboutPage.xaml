<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Registry_App.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24,18,24,18">
        <StackPanel MaxWidth="640" HorizontalAlignment="Left" Spacing="18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image
                    Width="72"
                    Height="72"
                    Source="ms-appx:///Assets/Square150x150Logo.scale-200.png" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock FontSize="28" FontWeight="SemiBold" Text="Registry" />
                    <TextBlock
                        x:Name="VersionText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <TextBlock
                FontSize="15"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="A modern registry editor for browsing, editing, importing, exporting, and checking registry data with a familiar Windows feel."
                TextWrapping="Wrap" />

            <TextBlock
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                Text="WinUI 3 • Windows App SDK • .NET"
                TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Page>
