<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Registry_App.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Registry_App.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    KeyDown="Page_KeyDown"
    mc:Ignorable="d">
    <Page.KeyboardAccelerators>
        <KeyboardAccelerator Key="F" Modifiers="Control" Invoked="FindAccelerator_Invoked" />
    </Page.KeyboardAccelerators>

    <Grid Padding="16,10,16,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="TopBar"
            ColumnSpacing="8"
            RowSpacing="8"
            SizeChanged="TopBar_SizeChanged">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="AddressColumn" Width="*" />
                <ColumnDefinition x:Name="FilterColumn" Width="260" />
                <ColumnDefinition x:Name="TypeColumn" Width="170" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                Width="30"
                Height="30"
                Padding="0"
                ToolTipService.ToolTip="Back"
                Click="Back_Click">
                <FontIcon FontSize="13" Glyph="&#xE72B;" />
            </Button>
            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                Width="30"
                Height="30"
                Padding="0"
                ToolTipService.ToolTip="Forward"
                Click="Forward_Click">
                <FontIcon FontSize="13" Glyph="&#xE72A;" />
            </Button>
            <Button
                x:Name="UpButton"
                Grid.Column="2"
                Width="30"
                Height="30"
                Padding="0"
                ToolTipService.ToolTip="Open parent key"
                Click="UpButton_Click">
                <FontIcon FontSize="13" Glyph="&#xE74A;" />
            </Button>
            <AutoSuggestBox
                x:Name="AddressBox"
                Grid.Column="3"
                MinWidth="180"
                PlaceholderText="HKEY_CURRENT_USER\Software"
                QueryIcon="Find"
                TextChanged="AddressBox_TextChanged"
                SuggestionChosen="AddressBox_SuggestionChosen"
                PreviewKeyDown="AddressBox_PreviewKeyDown"
                QuerySubmitted="AddressBox_QuerySubmitted" />
            <Grid
                x:Name="FilterHost"
                Grid.Row="1"
                Grid.ColumnSpan="6"
                ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="ValueFilterBox"
                    MinWidth="180"
                    Height="32"
                    PlaceholderText="Filter values"
                    TextChanged="ValueFilterBox_TextChanged" />
                <ComboBox
                    x:Name="ValueTypeFilter"
                    Grid.Column="1"
                    MinWidth="160"
                    SelectionChanged="ValueTypeFilter_SelectionChanged"
                    SelectedIndex="0">
                    <ComboBoxItem Content="All types" />
                    <ComboBoxItem Content="String" />
                    <ComboBoxItem Content="ExpandString" />
                    <ComboBoxItem Content="DWord" />
                    <ComboBoxItem Content="QWord" />
                    <ComboBoxItem Content="Binary" />
                    <ComboBoxItem Content="MultiString" />
                </ComboBox>
            </Grid>
        </Grid>

        <CommandBar
            x:Name="RegistryCommandBar"
            Grid.Row="1"
            DefaultLabelPosition="Right"
            Background="Transparent"
            Padding="8,0,0,0"
            IsDynamicOverflowEnabled="False">
            <CommandBar.Resources>
                <SolidColorBrush x:Key="CommandBarBackground" Color="Transparent" />
                <SolidColorBrush x:Key="CommandBarBackgroundOpen" Color="Transparent" />
                <SolidColorBrush x:Key="CommandBarOverflowButtonBackground" Color="Transparent" />
                <SolidColorBrush x:Key="CommandBarOverflowButtonBackgroundOpen" Color="Transparent" />
                <SolidColorBrush x:Key="CommandBarOverflowButtonBackgroundPointerOver" Color="#18FFFFFF" />
            </CommandBar.Resources>
            <AppBarButton x:Name="RefreshCommand" Icon="Refresh" Label="Refresh" Click="Refresh_Click" />
            <AppBarButton x:Name="FindCommand" Icon="Find" Label="Find" Click="Find_Click" />
            <AppBarButton x:Name="EditCommand" Margin="12,0,0,0" Icon="Edit" Label="Edit" Click="EditValue_Click" />
            <AppBarButton x:Name="DeleteValueCommand" Icon="Delete" Label="Delete" Click="DeleteValue_Click" />
            <AppBarToggleButton x:Name="FavoriteCommand" Margin="12,0,0,0" Icon="Favorite" Label="Favorite" Click="AddFavorite_Click" />
            <AppBarButton x:Name="CopyPathCommand" Icon="Copy" Label="Copy path" Click="CopyPath_Click" />
            <AppBarButton x:Name="CopyValueCommand" Icon="Copy" Label="Copy value" Click="CopyValue_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="PermissionsCommand" Icon="Permissions" Label="Permissions" Click="Permissions_Click" Visibility="Collapsed" />
            <AppBarToggleButton x:Name="MonitorCommand" Icon="View" Label="Monitor" Click="Monitor_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="ExportCommand" Icon="Save" Label="Export" Click="Export_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="ImportCommand" Icon="OpenFile" Label="Import" Click="Import_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="OverflowCommand" Icon="More" Label="More">
                <AppBarButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Name="CopyValueMenuItem" Text="Copy value" Click="CopyValue_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Copy" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="PermissionsMenuItem" Text="Permissions" Click="Permissions_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Permissions" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MonitorMenuItem" Text="Monitor" Click="Monitor_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="View" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="ExportMenuItem" Text="Export" Click="Export_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="Save" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="ImportMenuItem" Text="Import" Click="Import_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="OpenFile" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="LoadHiveMenuItem" Text="Load hive" Click="LoadHive_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="OpenFile" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="UnloadHiveMenuItem" Text="Unload hive" Click="UnloadHive_Click">
                            <MenuFlyoutItem.Icon>
                                <SymbolIcon Symbol="ClosePane" />
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </AppBarButton.Flyout>
            </AppBarButton>
            <AppBarButton x:Name="LoadHiveCommand" Icon="OpenFile" Label="Load hive" Click="LoadHive_Click" Visibility="Collapsed" />
            <AppBarButton x:Name="UnloadHiveCommand" Icon="ClosePane" Label="Unload hive" Click="UnloadHive_Click" Visibility="Collapsed" />
        </CommandBar>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TreePaneColumn" Width="340" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Margin="12,8,12,6"
                        FontWeight="SemiBold"
                        Text="Keys" />
                    <TreeView
                        x:Name="KeyTree"
                        Grid.Row="1"
                        ContextRequested="KeyTree_ContextRequested"
                        Expanding="KeyTree_Expanding"
                        ItemInvoked="KeyTree_ItemInvoked" />
                </Grid>
            </Border>

            <Thumb
                x:Name="PaneSplitter"
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                DragDelta="PaneSplitter_DragDelta">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Rectangle
                                Width="1"
                                HorizontalAlignment="Center"
                                Fill="{ThemeResource ControlStrokeColorDefaultBrush}" />
                        </Grid>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>

            <Border Grid.Column="2" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="36" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Padding="14,0,12,0" ColumnSpacing="14" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="CurrentPathText"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            ContextRequested="CurrentPathText_ContextRequested"
                            TextTrimming="CharacterEllipsis"
                            ToolTipService.ToolTip="Right click for key actions" />
                        <StackPanel
                            x:Name="CountPills"
                            Grid.Column="1"
                            Margin="0,0,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="8">
                            <Border
                                MinWidth="82"
                                Padding="8,3"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <TextBlock
                                    x:Name="KeyCountText"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                            <Border
                                MinWidth="74"
                                Padding="8,3"
                                Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <TextBlock
                                    x:Name="ValueCountText"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1" Background="{ThemeResource SubtleFillColorSecondaryBrush}" Padding="10,0,10,0" ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="ValueNameHeaderColumn" Width="120" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition x:Name="ValueTypeHeaderColumn" Width="84" />
                            <ColumnDefinition Width="6" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Name" />
                        <Thumb Grid.Column="1" DragDelta="ValueNameSplitter_DragDelta">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Grid Background="Transparent">
                                        <Border
                                            Width="2"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource TextFillColorTertiaryBrush}"
                                            CornerRadius="1"
                                            Opacity="0.42" />
                                    </Grid>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="Type" />
                        <Thumb Grid.Column="3" DragDelta="ValueTypeSplitter_DragDelta">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Grid Background="Transparent">
                                        <Border
                                            Width="2"
                                            Height="18"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource TextFillColorTertiaryBrush}"
                                            CornerRadius="1"
                                            Opacity="0.42" />
                                    </Grid>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                        <TextBlock Grid.Column="4" VerticalAlignment="Center" FontWeight="SemiBold" Text="Data" />
                    </Grid>
                    <ListView
                        x:Name="ValueList"
                        Grid.Row="2"
                        DoubleTapped="ValueList_DoubleTapped"
                        PointerPressed="ValueList_PointerPressed"
                        SelectionChanged="ValueList_SelectionChanged">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="36" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:RegistryValueRow">
                                <Grid
                                    MinHeight="36"
                                    Padding="10,0"
                                    Background="Transparent"
                                    ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{x:Bind NameColumnWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="{x:Bind TypeColumnWidth, Mode=OneWay}" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="{x:Bind DataColumnWidth, Mode=OneWay}" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind DisplayName}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind Kind}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{x:Bind DisplayData}" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel
                        x:Name="EmptyValuesPanel"
                        Grid.Row="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <FontIcon
                            FontSize="28"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Glyph="&#xE8A5;" />
                        <TextBlock
                            x:Name="EmptyValuesText"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="This key has no values." />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <InfoBar
            x:Name="StatusBar"
            Grid.Row="3"
            IsClosable="False"
            IsOpen="False" />
        <Border
            Grid.Row="4"
            Padding="10,6"
            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="StatusText"
                    VerticalAlignment="Center"
                    Text="Ready"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
                <ComboBox
                    x:Name="RegistryViewSelector"
                    Grid.Column="1"
                    MinWidth="128"
                    SelectionChanged="RegistryViewSelector_SelectionChanged"
                    SelectedIndex="1">
                    <ComboBoxItem Content="32-bit view" />
                    <ComboBoxItem Content="64-bit view" />
                </ComboBox>
            </Grid>
        </Border>
    </Grid>
</Page>
